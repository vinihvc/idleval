{
  "name": "idleval",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "vite",
    "build": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n/paraglide --emit-ts-declarations && tsc -b && vite build",
    "preview": "vite preview",
    "paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/i18n/paraglide --emit-ts-declarations",
    "remove-bg": "node scripts/remove-bg.mjs",
    "compress-image": "node scripts/compress-image.mjs",
    "i18n:check": "node scripts/check-i18n.mjs",
    "agents:check": "node scripts/check-agents-md.mjs",
    "lint:check": "ultracite check",
    "lint:fix": "ultracite fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.0",
    "@fontsource/almendra": "^5.2.8",
    "@fontsource/grenze-gotisch": "^5.2.8",
    "@fontsource/jersey-10": "^5.2.8",
    "@inlang/paraglide-js": "^2.18.2",
    "@inlang/paraglide-js-react": "^1.0.2",
    "@tailwindcss/vite": "^4.3.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@unpic/react": "^1.0.2",
    "break_infinity.js": "^2.2.0",
    "clsx": "^2.1.1",
    "jotai": "^2.20.0",
    "lucide-react": "^1.17.0",
    "pixelarticons": "^2.1.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "2.4.16",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser-playwright": "^4.1.8",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "^1.0.0",
    "lint-staged": "^17.0.7",
    "playwright": "^1.60.0",
    "pngquant-bin": "^9.0.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "ultracite": "7.8.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "pnpm dlx ultracite fix"
    ]
  }
}
